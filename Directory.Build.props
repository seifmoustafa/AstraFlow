<Project>
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Version>1.2.3</Version>
    <AssemblyVersion>1.2.3.0</AssemblyVersion>
    <FileVersion>1.2.3.0</FileVersion>
    <IsPackable>true</IsPackable>
    <Authors>AstraFlow Contributors</Authors>
    <Company>AstraFlow Contributors</Company>
    <Product>AstraFlow</Product>
    <Copyright>Copyright (c) AstraFlow Contributors</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/seifmoustafa/AstraFlow</PackageProjectUrl>
    <RepositoryUrl>https://github.com/seifmoustafa/AstraFlow</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReleaseNotes>AstraFlow 1.2.3:
      - Adds an automated clean-install package verification script for supported target frameworks.
      - Verifies core packages in netstandard2.0, net8.0, and net9.0 consumer projects.
      - Verifies all packages, including AstraFlow.Mapper.EntityFrameworkCore, in a net10.0 consumer project.
      - Wires package install verification into local packing, CI, and the publish workflow.
      - See CHANGELOG.md for the full release history.</PackageReleaseNotes>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>assets/branding/astraflow-icon.png</PackageIcon>
  </PropertyGroup>
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="" />
    <None Include="$(MSBuildThisFileDirectory)CHANGELOG.md" Pack="true" PackagePath="" />
    <None
      Include="$(MSBuildThisFileDirectory)assets\branding\astraflow-icon.png"
      Pack="true"
      PackagePath="assets\branding\"
    />
    <None Include="$(MSBuildThisFileDirectory)docs\*.md" Pack="true" PackagePath="docs\" />
    <Compile
      Include="$(MSBuildThisFileDirectory)src\Shared\IsExternalInit.cs"
      Link="Compatibility\IsExternalInit.cs"
      Condition="'$(TargetFramework)' == 'netstandard2.0'"
    />
  </ItemGroup>
</Project>
